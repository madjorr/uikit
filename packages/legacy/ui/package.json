{
  "name": "@acronis-platform/shadcn-uikit",
  "version": "0.36.1",
  "description": "Acronis shadcn UI component library built with TypeScript, following shadcn design principles",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./styles": "./dist/shadcn-uikit.css",
    "./styles/full": "./dist/shadcn-uikit-full.css",
    "./styles/tokens": "./dist/tokens.css",
    "./styles/base": "./dist/base.css",
    "./styles/components": "./dist/components.css",
    "./styles/utilities": "./dist/utilities.css",
    "./styles/themes": "./dist/themes/acronis-default.css",
    "./styles/themes/acronis-default": "./dist/themes/acronis-default.css",
    "./styles/themes/acronis-ocean": "./dist/themes/acronis-ocean.css",
    "./styles/themes/cyber-chat": "./dist/themes/cyber-chat.css",
    "./styles/themes/acronis-white-label": "./dist/themes/acronis-white-label.css",
    "./tailwind-preset": {
      "import": "./tailwind.preset.js",
      "types": "./tailwind.preset.d.ts",
      "require": "./tailwind.preset.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "tailwind.preset.js",
    "tailwind.preset.d.ts"
  ],
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:full-css && pnpm run build:llms",
    "build:full-css": "tsx scripts/build-full-css.ts",
    "build:lib": "vite build -c vite.lib.config.ts",
    "build:types": "tsc --project tsconfig.build.json",
    "build:llms": "tsx scripts/generate-llms-txt.ts",
    "clean": "rm -rf dist storybook-static node_modules/.vite *.tsbuildinfo",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "generate:icon-stories": "tsx scripts/generate-icon-stories.ts",
    "generate:themes": "tsx scripts/generate-white-label-themes.ts",
    "dev": "vite build -c vite.lib.config.ts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test:visual": "test-storybook",
    "storybook:test:visual:update": "test-storybook --updateSnapshot",
    "storybook:test:visual:docker": "pnpm storybook:build && docker compose -f ./docker-compose.storybook.yml up --build --abort-on-container-exit --exit-code-from test-runner",
    "storybook:test:visual:docker:update": "pnpm storybook:build && docker compose -f ./docker-compose.storybook.yml -f ./docker-compose.storybook.update.yml up --build --abort-on-container-exit --exit-code-from test-runner"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "@base-ui/react": "^1.0.0",
    "next-themes": "^0.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@base-ui/react": {
      "optional": true
    },
    "next-themes": {
      "optional": true
    },
    "tw-animate-css": {
      "optional": true
    }
  },
  "dependencies": {
    "@hookform/resolvers": "catalog:",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-slot": "1.2.4",
    "@tanstack/react-table": "catalog:",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.0",
    "cmdk": "1.1.1",
    "culori": "4.0.2",
    "date-fns": "catalog:",
    "embla-carousel-react": "8.6.0",
    "next-themes": "catalog:",
    "react-day-picker": "9.13.0",
    "react-hook-form": "catalog:",
    "react-resizable-panels": "4.1.1",
    "recharts": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "2.2.0",
    "vaul": "1.1.2",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "@playwright/test": "1.56.1",
    "@storybook/addon-a11y": "10.2.10",
    "@storybook/addon-docs": "10.2.10",
    "@storybook/addon-links": "10.2.10",
    "@storybook/addon-vitest": "10.2.10",
    "@storybook/react": "10.2.10",
    "@storybook/react-vite": "10.2.10",
    "@storybook/test-runner": "0.24.2",
    "@testing-library/jest-dom": "6.2.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "5.1.1",
    "@vitest/browser-playwright": "4.0.17",
    "@tailwindcss/cli": "4.2.2",
    "@tailwindcss/postcss": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "20.8.9",
    "http-server": "14.1.1",
    "jest-image-snapshot": "6.5.2",
    "postcss": "8.5.10",
    "sass-embedded": "1.97.2",
    "storybook": "10.2.10",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "tsx": "4.22.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "4.3.0",
    "vite-plugin-svgr": "4.5.0",
    "vitest": "catalog:"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "shadcn",
    "typescript",
    "uikit",
    "multi-framework",
    "acronis"
  ],
  "author": "Acronis International GmbH",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
