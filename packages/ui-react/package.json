{
  "name": "@acronis-platform/ui-react",
  "version": "0.2.0",
  "description": "Acronis React component library — a Base UI implementation, themed by @acronis-platform/design-tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./styles": "./dist/ui-react.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build -c vite.lib.config.ts",
    "dev": "vite build -c vite.lib.config.ts --watch",
    "clean": "rm -rf dist storybook-static node_modules/.vite *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "storybook": "storybook dev -p 6007",
    "storybook:build": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@acronis-platform/design-assets": "workspace:*",
    "@acronis-platform/design-theme": "workspace:*",
    "@base-ui/react": "catalog:",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@acronis-platform/shadcn-uikit-demos": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-links": "10.4.1",
    "@storybook/react": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "5.1.1",
    "@tailwindcss/postcss": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "20.9.0",
    "storybook": "10.4.1",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "5.0.1",
    "vitest": "catalog:"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "base-ui",
    "typescript",
    "uikit",
    "acronis"
  ],
  "author": "Acronis International GmbH",
  "license": "MIT",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}
