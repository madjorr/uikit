{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node"],
    "target": "ES2022",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "moduleDetection": "force"
  },
  "include": [
    "*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "grammar/**/*.ts",
    "screens/**/*.ts",
    "__tests__/**/*.ts"
  ]
}
