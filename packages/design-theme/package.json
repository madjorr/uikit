{
  "name": "@acronis-platform/design-theme",
  "version": "0.2.0",
  "description": "Acronis design theme. CSS / SCSS / JS artifacts generated from @acronis-platform/design-tokens via Style Dictionary.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./css": "./dist/css/variables.css",
    "./scss": "./dist/scss/_variables.scss",
    "./js": {
      "types": "./dist/js/index.d.ts",
      "import": "./dist/js/index.js"
    }
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "dev": "tsx scripts/build.ts",
    "clean": "rm -rf dist",
    "lint": "echo \"no lint (generated artifacts; source is @acronis-platform/design-tokens)\" && exit 0",
    "lint:fix": "echo \"no lint (generated artifacts)\" && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build",
    "test:watch": "echo \"no watch mode (run test)\" && exit 0"
  },
  "keywords": [
    "design-tokens",
    "theme",
    "style-dictionary",
    "css-variables",
    "acronis"
  ],
  "dependencies": {
    "@acronis-platform/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "style-dictionary": "catalog:",
    "tsx": "4.22.3",
    "typescript": "catalog:"
  }
}
