{
  "name": "shadcn-uikit-monorepo",
  "private": true,
  "description": "The Acronis UI Shadcn UI components library with color schemes and demos",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "changeset": "changeset",
    "clean": "pnpm -r clean",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "husky": "pnpm run lint-staged && pnpm run typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "release": "changeset publish",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "typecheck": "pnpm -r typecheck",
    "version": "changeset version"
  },
  "keywords": [
    "ui",
    "components",
    "shadcn",
    "react",
    "tailwind"
  ],
  "author": "Acronis International GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acronis/shadcn-uikit.git"
  },
  "bugs": {
    "url": "https://github.com/acronis/shadcn-uikit/issues"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "^9.38.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "10.4.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.60.0"
  },
  "lint-staged": {
    "apps/**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ],
    "packages/**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.27.0"
}
