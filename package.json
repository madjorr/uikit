{
  "name": "shadcn-uikit-monorepo",
  "private": true,
  "description": "The Acronis UI Shadcn UI components library with color schemes and demos",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "husky": "pnpm run lint-staged && pnpm run typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "ui",
    "components",
    "shadcn",
    "react",
    "tailwind"
  ],
  "author": "Acronis International GmbH",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acronis/shadcn-uikit.git"
  },
  "bugs": {
    "url": "https://github.com/acronis/shadcn-uikit/issues"
  },
  "devDependencies": {
    "@commitlint/cli": "20.3.1",
    "@commitlint/config-conventional": "20.3.1",
    "@eslint/js": "^9.15.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-storybook": "10.1.10",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.12.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.7.4",
    "typescript": "catalog:",
    "typescript-eslint": "^8.15.0"
  },
  "lint-staged": {
    "apps/**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ],
    "packages/**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ],
    "apps/**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "packages/**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.27.0"
}
