# Copy this file to .env.local in the CONSUMER package directory (e.g. packages/design-assets/)
# and fill in the values. .env.local is gitignored.

# Required: Figma personal access token (Settings → Personal access tokens)
FIGMA_SYNC_TOKEN=

# Required: Figma file key (from the file URL: figma.com/design/<FILE_KEY>/...)
FIGMA_SYNC_FILE_KEY=

# Required: Node ID of the frame containing _assetsource/* components
# Accepts both colon form (629:10610) and hyphen form (629-10610) as copied from a URL
FIGMA_SYNC_FRAME_NODE_ID=

# Optional: pack name — defaults to "icons-stroke-mono"
# FIGMA_SYNC_PACK_NAME=icons-stroke-mono

# Optional: comma-separated platform list — defaults to "PD"
# FIGMA_SYNC_PLATFORMS=PD
